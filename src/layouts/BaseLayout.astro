---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  ogType = 'website',
} = Astro.props;

const siteUrl   = 'https://lastagous.com';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0a0f1e" />
  <link rel="canonical" href={canonical} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <meta property="og:type"        content={ogType} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={`${siteUrl}${ogImage}`} />
  <meta property="og:locale"      content="ja_JP" />
  <meta property="og:site_name"   content="lastagous.com" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={`${siteUrl}${ogImage}`} />

  <link rel="icon" type="image/png" href="/favicon-hat.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "lastagous.com",
    "url": siteUrl,
    "description": "FF14 攻略ツール・ガイド集",
    "inLanguage": "ja",
  })} />
</head>

<body>
  <div class="pointer-events-none fixed inset-0 overflow-hidden" aria-hidden="true">
    <div class="star-field"></div>
  </div>

  <slot />
</body>
</html>

<style is:global>
  .star-field {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(200,216,240,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 50%, rgba(200,216,240,0.4) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 50% 15%, rgba(200,216,240,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 70%, rgba(200,216,240,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 30%, rgba(200,216,240,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 80%, rgba(200,216,240,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 80% 90%, rgba(200,216,240,0.3) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 60% 40%, rgba(45,212,191,0.3) 0%, transparent 100%);
    opacity: 0.7;
  }
</style>
